# Relaxed analyzer rules for sample / demo projects under extra-projects/
# (e.g. AdventureWorks-EF6 — auto-generated EF models from a real database)
#
# Lives alongside the demo content rather than the repo root so the root
# .editorconfig stays byte-identical to the canonical repo-template.
[*.cs]
dotnet_diagnostic.SA1300.severity = none
dotnet_diagnostic.IDE1006.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.RS0030.severity = none
dotnet_diagnostic.AsyncFixer01.severity = none
dotnet_diagnostic.AsyncFixer02.severity = none
dotnet_diagnostic.MA0004.severity = none
dotnet_diagnostic.S3216.severity = none
dotnet_diagnostic.CA2007.severity = none
